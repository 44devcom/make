# Copy to .env in this directory. Use --project-directory examples when running from repo root.

IMAGE_NAME=xrdp:local

# Space-separated install.sh components: tools chrome docker xrdp-gnome xrdp-xfce
INSTALL_MODULES=tools chrome xrdp-xfce

# xfce4 = faster; task-xfce-desktop = full ~720MB+ desktop metapackage
XFCE_METAPACKAGE=xfce4

# Published RDP port (XRDP). Maps host:${RDP_HOST_PORT} → container:3389
RDP_HOST_PORT=3390

# After install, start xrdp when CMD is sleep infinity (default). Set 0 to skip.
START_XRDP=1

# RDP as root: set a password (Debian images often have locked root). Optional but required to log in.
XRDP_ROOT_PASSWORD=Adm12345
XRDP_ALLOW_ROOT=1

# Optional runtime user provisioning
USERADD_USERS="junior:Adm1234#:docker,sudo"
USERADD_DEFAULT_SHELL=/bin/bash
USERADD_DEFAULT_GROUPS=sudo
USERADD_DEFAULT_PASSWORD=Adm12345

# Override script source base (default: file:///install/bin/ inside the image)
# REPOSITORY=file:///install/bin/


# Shared writable bind mount (host <-> container)
SHARED_HOST_DIR=./shared
SHARED_CONTAINER_DIR=/shared

# deploy.resources limits/reservations
SERVICE_CPUS_LIMIT=8
SERVICE_MEMORY_LIMIT=8192M
SERVICE_CPUS_RESERVATION=1
SERVICE_MEMORY_RESERVATION=1024M
